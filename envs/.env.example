# ─── Database ────────────────────────────────────────────
DATABASE_URL="postgresql://app:app@localhost:5432/app?schema=public"

# ─── Auth ────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-long-random-string"

# ─── API ─────────────────────────────────────────────────
PORT=4000
FRONTEND_ORIGIN="http://localhost:3000"

# ─── Stripe ──────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
